    <style>
        /* Responsive base styles */
        @media (max-width: 640px) {
            .max-w-7xl { max-width: 100% !important; }
            .px-4 sm:px-6 { padding-left: 1rem !important; padding-right: 1rem !important; }
            .py-10 { padding-top: 2rem !important; padding-bottom: 2rem !important; }
            .h-auto min-h-[80px] sm:h-36 { min-height: 80px !important; height: auto !important; }
            .text-2xl sm:text-4xl sm:text-6xl { font-size: 2.5rem !important; }
            .text-xl sm:text-3xl { font-size: 1.5rem !important; }
            .text-xl sm:text-2xl { font-size: 1.25rem !important; }
            .gap-4 sm:gap-6 { gap: 1rem !important; }
            .w-10 sm:w-14 { width: 2.5rem !important; }
            .h-8 sm:h-10 sm:h-14 { height: 2.5rem !important; }
            .p-4 sm:p-8 { padding: 1.5rem !important; }
        }
        @media (max-width: 768px) {
            .max-w-7xl { max-width: 100% !important; }
            .grid-cols-12 { grid-template-columns: repeat(1, minmax(0, 1fr)) !important; }
            .col-span-12 sm:col-span-8, .col-span-12 sm:col-span-4 { grid-column: span 12 / span 12 !important; }
            .lg\:text-2xl sm:text-4xl { font-size: 2rem !important; }
            .lg\:text-xl sm:text-2xl { font-size: 1.5rem !important; }
        }
        @media (max-width: 1024px) {
            .max-w-7xl { max-width: 95% !important; }
        }
        /* Responsive images */
        img { max-width: 100%; height: auto; }
        /* Responsive text scaling */
        .responsive-heading { font-size: clamp(1.5rem, 4vw, 3rem); }
        .responsive-subheading { font-size: clamp(1.125rem, 3vw, 2rem); }
        .responsive-text { font-size: clamp(0.875rem, 2vw, 1.125rem); }
    /* ===== RESPONSIVE ADAPTIVE STYLES ===== */
        @media (max-width: 640px) {
            .container-responsive { padding-left: 1rem; padding-right: 1rem; }
            .text-responsive-xl { font-size: clamp(1.25rem, 4vw, 2.5rem); }
            .text-responsive-lg { font-size: clamp(1.125rem, 3vw, 2rem); }
            .text-responsive-md { font-size: clamp(1rem, 2.5vw, 1.25rem); }
            .text-responsive-sm { font-size: clamp(0.875rem, 2vw, 1rem); }
            .h-nav { min-height: 80px; height: auto; }
            .icon-nav { width: 2.5rem; height: 2.5rem; font-size: 1.5rem; }
            .gap-nav { gap: 0.5rem; }
        }
        @media (min-width: 641px) and (max-width: 1024px) {
            .container-responsive { max-width: 95%; }
            .text-responsive-xl { font-size: clamp(1.5rem, 3vw, 3rem); }
            .text-responsive-lg { font-size: clamp(1.25rem, 2.5vw, 2rem); }
        }
        @media (min-width: 1025px) {
            .container-responsive { max-width: 1200px; }
        }
        img, picture, svg { max-width: 100%; height: auto; }
        .responsive-img { width: 100%; height: auto; object-fit: contain; }
        /* Touch targets mínimos 44px para móvil */
        button, a { min-height: 44px; min-width: 44px; }
</style>

  <style>
         html { overflow-x: auto; -webkit-overflow-scrolling: touch; }
         body { min-width: 320px; word-wrap: break-word; overflow-wrap: break-word; }
         .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .active-tab-indicator {
            border-bottom: 4px solid #00738b;
        }
        .accessibility-bar {
            writing-mode: vertical-rl;
            transform: rotate(180deg);
        }
        
        .stylized-icon {
            display: flex;
            align-items: center;
            justify-content: center;
            height: 60px;
            width: 60px;
            color: #00738b;
            font-family: "Public Sans", sans-serif;
            font-size: 42px;
            font-weight: 700;
            line-height: 1;
            position: relative;
        }
        
        .icon-border-c {
            border: 3px solid #00738b;
            border-right: none;
            border-radius: 12px 0 0 12px;
            width: 35px;
            height: 45px;
            position: relative;
        }
        .icon-border-c::after {
            content: '';
            position: absolute;
            right: -10px;
            top: 0;
            width: 15px;
            height: 3px;
            background: #00738b;
        }
        .icon-border-c::before {
            content: '';
            position: absolute;
            right: -10px;
            bottom: 0;
            width: 15px;
            height: 3px;
            background: #00738b;
        }

        .icon-t {
            width: 45px;
            height: 45px;
            border-top: 5px solid #00738b;
            border-left: 1px solid transparent;
            position: relative;
        }
        .icon-t::after {
            content: '';
            position: absolute;
            left: 50%;
            top: 0;
            width: 4px;
            height: 100%;
            background: #00738b;
            transform: translateX(-50%);
        }
        .icon-t::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            width: 12px;
            height: 12px;
            background: #8ecbd6;
            z-index: -1;
        }

        .icon-p {
            width: 35px;
            height: 45px;
            border: 3px solid #00738b;
            border-radius: 0 15px 15px 0;
            position: relative;
        }
        .icon-p::after {
            content: '';
            position: absolute;
            left: -3px;
            top: 0;
            height: 60px;
            width: 4px;
            background: #00738b;
        }

        .icon-e {
            width: 35px;
            height: 45px;
            border: 3px solid #00738b;
            border-right: none;
            position: relative;
        }
        .icon-e::after {
            content: '';
            position: absolute;
            left: 0;
            top: 50%;
            width: 25px;
            height: 3px;
            background: #00738b;
            transform: translateY(-50%);
        }
.icon-e::before {
             content: '';
             position: absolute;
             left: 5px;
             top: 50%;
             width: 15px;
             height: 10px;
             background: #8ecbd6;
             z-index: -1;
             transform: translateY(-50%);
         }
         
         /* Responsive adjustments */
         @media (max-width: 640px) {
             .accessibility-bar {
                 display: none;
             }
             nav ul {
                 flex-wrap: wrap;
             }
             nav li {
                 flex: 1 1 50%;
                 max-width: 50%;
             }
             .h-auto min-h-[80px] sm:h-36 {
                 height: auto;
                 min-height: 100px;
             }
             .max-h-40 {
                 max-height: 30vh;
             }
             .px-4 sm:px-6 {
                 padding-left: 1rem;
                 padding-right: 1rem;
             }
         }
    /* ===== RESPONSIVE ADAPTIVE STYLES ===== */
        @media (max-width: 640px) {
            .container-responsive { padding-left: 1rem; padding-right: 1rem; }
            .text-responsive-xl { font-size: clamp(1.25rem, 4vw, 2.5rem); }
            .text-responsive-lg { font-size: clamp(1.125rem, 3vw, 2rem); }
            .text-responsive-md { font-size: clamp(1rem, 2.5vw, 1.25rem); }
            .text-responsive-sm { font-size: clamp(0.875rem, 2vw, 1rem); }
            .h-nav { min-height: 80px; height: auto; }
            .icon-nav { width: 2.5rem; height: 2.5rem; font-size: 1.5rem; }
            .gap-nav { gap: 0.5rem; }
        }
        @media (min-width: 641px) and (max-width: 1024px) {
            .container-responsive { max-width: 95%; }
            .text-responsive-xl { font-size: clamp(1.5rem, 3vw, 3rem); }
            .text-responsive-lg { font-size: clamp(1.25rem, 2.5vw, 2rem); }
        }
        @media (min-width: 1025px) {
            .container-responsive { max-width: 1200px; }
        }
        img, picture, svg { max-width: 100%; height: auto; }
        .responsive-img { width: 100%; height: auto; object-fit: contain; }
        /* Touch targets mínimos 44px para móvil */
        button, a { min-height: 44px; min-width: 44px; }
</style>
</head>
